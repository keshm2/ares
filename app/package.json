{
  "name": "@keshm/applyr",
  "version": "0.8.2-alpha.0",
  "description": "Terminal UI overlay for applyr — manual job search, automatic runs, review triage, status, and history over the Python core. The unscoped npm name 'applyr' belongs to an unrelated package.",
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keshm2/ares.git",
    "directory": "app"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "applyr": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/cli.js status"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.0"
  }
}
